# ─── Shared Infrastructure ───────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

KAFKA_BROKERS=kafka:9092

# ─── User Service ────────────────────────────────────────────────────────────
USER_SERVICE_PORT=8001
USER_DB_NAME=ecommerce_users
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# ─── Cart Service ────────────────────────────────────────────────────────────
CART_SERVICE_PORT=8002
CART_DB_NAME=ecommerce_carts
PRODUCT_SERVICE_URL=http://product-service:8081

# ─── Payment Service ─────────────────────────────────────────────────────────
PAYMENT_SERVICE_PORT=8003
PAYMENT_DB_NAME=ecommerce_payments
KAFKA_CONSUMER_GROUP=payment-service

# ─── Product Service ─────────────────────────────────────────────────────────
PRODUCT_SERVICE_PORT=8081
PRODUCT_DB_NAME=ecommerce_products

# ─── Order Service ───────────────────────────────────────────────────────────
ORDER_SERVICE_PORT=8082
ORDER_DB_NAME=ecommerce_orders

# ─── Environment ─────────────────────────────────────────────────────────────
ENV=development